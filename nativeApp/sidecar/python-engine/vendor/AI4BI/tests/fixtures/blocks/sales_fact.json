{
  "block_id": "sales_fact",
  "block_type": "fact",
  "grain": "order_id",
  "version": "1.0.0",
  "description": "Order-level sales fact table. One row per sales order line. Contains intentional null/zero/orphan rows for robustness testing.",
  "block_lifecycle": "validated",
  "primary_keys": ["order_id"],
  "columns": [
    {
      "name": "order_id",
      "data_type": "string",
      "pii_level": "none",
      "nullable": false,
      "description": "Unique order identifier"
    },
    {
      "name": "order_date",
      "data_type": "date",
      "pii_level": "none",
      "nullable": false,
      "description": "Date the order was placed (YYYY-MM-DD)"
    },
    {
      "name": "region",
      "data_type": "string",
      "pii_level": "none",
      "nullable": true,
      "description": "Sales region: North, South, East; null for unrouted orders"
    },
    {
      "name": "product_id",
      "data_type": "string",
      "pii_level": "none",
      "nullable": true,
      "description": "FK to product_dim; null for orphan rows"
    },
    {
      "name": "category",
      "data_type": "string",
      "pii_level": "none",
      "nullable": true,
      "description": "Product category: Electronics, Apparel, Food; null for uncategorised rows"
    },
    {
      "name": "revenue",
      "data_type": "float",
      "pii_level": "none",
      "nullable": true,
      "description": "Gross revenue in USD; null when order is voided/orphaned"
    },
    {
      "name": "cost",
      "data_type": "float",
      "pii_level": "none",
      "nullable": true,
      "description": "Cost of goods sold in USD; null when revenue is null"
    },
    {
      "name": "quantity",
      "data_type": "integer",
      "pii_level": "none",
      "nullable": false,
      "description": "Number of units ordered (0 for cancelled lines)"
    }
  ],
  "metrics": [
    {
      "name": "revenue",
      "formula": "SUM(revenue)",
      "disaggregation_method": "sum",
      "unit": "USD",
      "description": "Total gross revenue; NULL rows excluded by SUM semantics"
    },
    {
      "name": "gross_profit",
      "formula": "SUM(revenue - cost)",
      "disaggregation_method": "sum",
      "unit": "USD",
      "description": "Revenue minus cost of goods sold; computed row-wise then aggregated"
    }
  ],
  "relationships": [
    {
      "target_block_id": "product_dim",
      "allowed_join_keys": ["product_id"],
      "join_type": "left",
      "fanout_risk": "LOW",
      "description": "Left join to product dimension on product_id; many-to-one relationship, no fanout risk"
    }
  ],
  "policy": {
    "data_classification": "internal",
    "row_filter_expr": null,
    "allowed_roles": ["analyst", "manager", "data_admin"]
  },
  "data_source": {
