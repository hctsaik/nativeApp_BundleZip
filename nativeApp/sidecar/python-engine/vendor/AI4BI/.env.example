# AI4BI — Environment Variables
# Copy to .env and fill in values (never commit .env to version control)

# ── NL2 Mode ──────────────────────────────────────────────────────────────
# LLM_MODE=mock          (default) Deterministic keyword routing; no API calls.
#                         Safe for CI, local dev without a key, and offline use.
# LLM_MODE=anthropic     Use Claude API for intent classification.
#                         Requires ANTHROPIC_API_KEY.  Falls back to mock on
#                         error or missing key.
LLM_MODE=mock

# ── Anthropic API ─────────────────────────────────────────────────────────
# Required only when LLM_MODE=anthropic
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Anthropic Model ───────────────────────────────────────────────────────
# Default: claude-haiku-4-5-20251001 (fast, low cost for classification)
# Other options: claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
