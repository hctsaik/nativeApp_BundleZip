# 機器專屬設定
.mcp.json
.claude/

# Labeling 外掛以外部資料夾（repo: ANnoTation）提供，透過目錄 junction 掛載到
# plugins/labeling（見 scripts/win/link-labeling.bat）。junction 內容由 ANnoTation
# 自己的 git 版控，不在本 repo 追蹤。
sidecar/python-engine/plugins/labeling/

# 大型二進位 / 測試資料
external_exe/
testData/
*.pt

# PyInstaller
sidecar/python-engine/dist/
sidecar/python-engine/build/
sidecar/python-engine/*.spec.bak
sidecar/python-engine/config/*.bak

# Bundled standalone Python for release (fetched at build time, ~150MB; never committed)
apps/host-electron/python-runtime/

# tools.sqlite 是 per-device 衍生快取（每次 boot / --rebuild-catalog 從
# plugin.yaml + sheet YAML + config/seed.yaml 重建），不進版控。
# 詳見 docs/platform/catalog-source-of-truth-discussion.md
sidecar/python-engine/config/*.sqlite

# per-tool venvs（core/tool_deps.py 依 plugin.yaml requires: 自動重建的隔離快取），不進版控
sidecar/python-engine/.tool-venvs/

# pytest cache
.pytest_cache/

# /goal command artifact (transient prompt scratch, not versioned)
docs/goal.md
