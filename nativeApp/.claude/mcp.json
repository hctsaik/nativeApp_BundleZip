{
  "mcpServers": {
    "platform": {
      "command": "python",
      "args": ["-m", "platform_mcp.server"],
      "cwd": "C:/code/claude/nativeApp/mcp",
      "env": {
        "CIM_SIDECAR_PORT": "8765"
      }
    },
    "cim-gui": {
      "command": "python",
      "args": ["-m", "cim_gui_mcp.server"],
      "cwd": "C:/code/claude/nativeApp/mcp",
      "env": {
        "CIM_SIDECAR_PORT": "8765",
        "CIM_MCP_HEADLESS": "1",
        "CIM_MCP_TIMEOUT": "10000"
      }
    },
    "annotation": {
      "command": "python",
      "args": ["-m", "plugins.labeling.mcp.server"],
      "cwd": "C:/code/claude/nativeApp/sidecar/python-engine",
      "env": {
        "ANNOTATION_WORKSPACE": "C:/code/claude/nativeApp/apps/host-electron/logs/annotation_workspace"
      }
    }
  }
}
